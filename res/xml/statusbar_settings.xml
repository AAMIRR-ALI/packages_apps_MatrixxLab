<PreferenceScreen
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tenx="http://schemas.android.com/apk/res-auto"
    xmlns:settings="http://schemas.android.com/apk/res-auto"
    android:key="statusbar_options"
    android:title="@string/statusbar_options_title">

     <PreferenceCategory
          android:title="Statusbar icons">

          <com.tenx.support.preferences.TenXPreference
               android:key="icon_manager"
               tenx:position="top"
               android:title="@string/icon_manager_title"
               android:summary="@string/icon_manager_summary">
          <intent android:action="com.android.settings.action.STATUS_BAR_TUNER" />
          </com.tenx.support.preferences.TenXPreference>

          <com.tenx.support.preferences.TenXPreference
               android:key="network_traffic_state"
               tenx:position="middle"
               android:title="@string/network_traffic_state_title"
               android:summary="@string/network_traffic_state_summary"
               android:defaultValue="false"
               android:fragment="com.android.settings.pixelage.networktraffic.NetworkTrafficSettings" />

          <com.tenx.support.preferences.TenXPreference
               android:key="ongoing_progress_settings"
               tenx:position="middle"
               android:title="@string/ongoing_progress_settings_title"
               android:summary="@string/ongoing_progress_settings_summary"
               android:fragment="com.android.settings.fragments.OngoingProgressBar" />

          <com.tenx.support.preferences.SystemSettingSwitchPreference
               android:key="statusbar_colored_icons"
               tenx:position="middle"
               android:title="@string/status_bar_colored_icons_title"
               android:summary="@string/status_bar_colored_icons_summary"
	       android:defaultValue="false" />

 	     <com.tenx.support.preferences.SystemSettingSwitchPreference
               android:key="wifi_standard_icon"
	       tenx:position="middle"
               android:title="@string/wifi_standard_icon_title"
               android:summary="@string/wifi_standard_icon_summary"
	       android:defaultValue="false" />

	  <!-- Data disabled icon -->
          <com.tenx.support.preferences.SystemSettingSwitchPreference
	       android:key="data_disabled_icon"
	       tenx:position="middle"
               android:title="@string/status_bar_data_disabled_icon_title"
               android:summary="@string/status_bar_data_disabled_icon_summary"
               android:defaultValue="true" />

          <com.tenx.support.preferences.SystemSettingSwitchPreference
               android:key="statusbar_notif_count"
               tenx:position="bottom"
               android:title="@string/status_bar_notif_count_title"
               android:summary="@string/status_bar_notif_count_summary"
               android:defaultValue="false" />
     
     </PreferenceCategory>

     <PreferenceCategory
          android:title="@string/privacy_indicators_title"
          android:summary="@string/privacy_indicators_summary">

        <com.tenx.support.preferences.SecureSettingSwitchPreference
               android:key="mic_camera_privacy_indicators"
               tenx:position="top"
               android:title="@string/mic_camera_privacy_indicators_title"
               android:summary="@string/mic_camera_privacy_indicators_summary"
               android:defaultValue="true" />

        <com.tenx.support.preferences.SecureSettingSwitchPreference
               android:key="location_privacy_indicator"
               tenx:position="bottom"
               android:title="@string/location_privacy_indicator_title"
               android:summary="@string/location_privacy_indicator_summary"
               android:defaultValue="true" />

    </PreferenceCategory>

     <PreferenceCategory
        android:key="status_bar_clock_key"
        android:title="@string/status_bar_clock_and_date_title">

          <com.tenx.support.preferences.TenXPreference
               android:key="clock"
               tenx:position="top"
               android:title="@string/status_bar_clock_and_date_title"
               android:summary="@string/status_bar_clock_and_date_summary"
               android:fragment="com.android.settings.fragments.Clock" />

          <!-- Status bar chip bg style -->
          <com.tenx.support.preferences.SystemSettingListPreference
               android:key="statusbar_clock_chip"
               tenx:position="bottom"
               android:title="@string/statusbar_clock_chip_title"
               android:entries="@array/statusbar_clock_chip_entries"
               android:entryValues="@array/statusbar_clock_chip_values"
               android:summary="%s"
               android:defaultValue="0" />

    </PreferenceCategory>

     <PreferenceCategory
          android:title="Logo">

          <!-- Logo -->
          <com.tenx.support.preferences.SystemSettingSwitchPreference
               android:key="status_bar_logo"
               tenx:position="top"
               android:title="@string/status_bar_logo_title"
               android:summary="@string/status_bar_logo_summary"
               android:defaultValue="false" />

          <!-- Logo position -->
          <com.tenx.support.preferences.SystemSettingListPreference
               android:key="status_bar_logo_position"
               tenx:position="middle"
               android:title="@string/status_bar_logo_position_title"
               android:entries="@array/status_bar_logo_position_entries"
               android:entryValues="@array/status_bar_logo_position_values"
               android:defaultValue="0"
               android:dependency="status_bar_logo" />

          <!-- Logo style -->
          <com.tenx.support.preferences.SystemSettingListPreference
               android:key="status_bar_logo_style"
               tenx:position="middle"
               android:title="@string/status_bar_logo_style_title"
               android:entries="@array/status_bar_logo_style_entries"
               android:entryValues="@array/status_bar_logo_style_values"
               android:defaultValue="0"
               android:dependency="status_bar_logo" />

          <!-- Logo color type -->
          <com.tenx.support.preferences.SystemSettingListPreference
               android:key="status_bar_logo_color"
               tenx:position="middle"
               android:title="@string/status_bar_logo_color_title"
               android:entries="@array/status_bar_logo_color_entries"
               android:entryValues="@array/status_bar_logo_color_values"
               android:dependency="status_bar_logo"
               android:defaultValue="0" />
               
          <!-- Logo custom color -->
          <com.tenx.support.colorpicker.ColorPickerPreference
               android:key="status_bar_logo_color_picker"
               tenx:position="bottom"
               android:title="@string/status_bar_logo_color_custom"
               settings:defaultValue="0xFFFFFFFF" />

     </PreferenceCategory>

     <PreferenceCategory
          android:title="statusbar lyric">

          <com.tenx.support.preferences.TenXPreference
               android:key="status_bar_lyrics"
               tenx:position="full"
               android:title="@string/status_bar_lyric_title"
               android:summary="@string/status_bar_lyric_summary"
               android:fragment="com.android.settings.fragments.StatusBarLyrics" />

     </PreferenceCategory>

     <PreferenceCategory
        android:title="@string/statusbar_extra_padding_category">

          <com.tenx.support.preferences.SystemSettingSeekBarPreference
               android:key="statusbar_extra_padding_start"
               tenx:position="top"
               android:title="@string/statusbar_extra_padding_start_title"
               android:defaultValue="0"
               settings:interval="1"
               settings:units="@string/unit_pixels"
               android:max="30"
               settings:min="-30" />

          <com.tenx.support.preferences.SystemSettingSeekBarPreference
               android:key="statusbar_extra_padding_top"
               tenx:position="middle"
               android:title="@string/statusbar_extra_padding_top_title"
               android:defaultValue="0"
               settings:interval="1"
               settings:units="@string/unit_pixels"
               android:max="30"
               settings:min="-30" />

          <com.tenx.support.preferences.SystemSettingSeekBarPreference
               android:key="statusbar_extra_padding_end"
               tenx:position="bottom"
               android:title="@string/statusbar_extra_padding_end_title"
               android:defaultValue="0"
               settings:interval="1"
               settings:units="@string/unit_pixels"
               android:max="30"
               settings:min="-30" />

    </PreferenceCategory>

    <PreferenceCategory
        android:key="status_bar_gestures_category"
        android:title="@string/status_bar_gestures_category_title">

        <!-- Status bar brightness control -->
        <com.tenx.support.preferences.SystemSettingSwitchPreference
            android:key="status_bar_brightness_control"
            tenx:position="full"
            android:title="@string/status_bar_brightness_control_title"
            android:summary="@string/status_bar_brightness_control_summary"
            android:defaultValue="false" />

    </PreferenceCategory>

</PreferenceScreen>
